# Docker Compose (docker-compose.yml): COMPOSE_DEBUG/COMPOSE_OPENAPI/COMPOSE_SANDBOX override
# container defaults when set. Omit them for local dev (Swagger + sandbox on).

# Application
APP_NAME=Avok
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-generate-a-long-random-secret
API_V1_PREFIX=/api/v1

# Payment webhooks: required when DEBUG=false (see README / payments callback)
PAYMENT_WEBHOOK_SECRET=change-me-shared-secret-for-payment-callbacks
# Sandbox simulate endpoints (local/staging only; set false in production)
ENABLE_PAYMENT_SANDBOX=true

# MTN MoMo Collection API (optional — enables live request-to-pay for provider mtn)
# MTN_MOMO_BASE_URL=https://sandbox.momodeveloper.mtn.com
# MTN_MOMO_SUBSCRIPTION_KEY=
# MTN_MOMO_API_USER=
# MTN_MOMO_API_KEY=
# MTN_MOMO_TARGET_ENVIRONMENT=sandbox
# MTN_MOMO_CURRENCY=EUR

# Database
DATABASE_URL=postgresql+asyncpg://avok_user:avok_pass@localhost:5432/avok_db
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=40

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=50

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# JWT (must not use the placeholder value "your-jwt-secret-key")
JWT_SECRET_KEY=change-me-generate-a-long-random-jwt-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# AWS S3
AWS_ACCESS_KEY_ID=your-aws-key
AWS_SECRET_ACCESS_KEY=your-aws-secret
AWS_S3_BUCKET=avok-storage
AWS_S3_REGION=us-east-1

# SMS (Africa's Talking)
AFRICASTALKING_USERNAME=sandbox
AFRICASTALKING_API_KEY=your-api-key
AFRICASTALKING_SENDER_ID=AVOK

# Email (SendGrid)
SENDGRID_API_KEY=your-sendgrid-key
SENDGRID_FROM_EMAIL=noreply@avok.com

# Escrow Settings
ESCROW_RELEASE_DAYS=14
ESCROW_REMINDER_DAY_1=7
ESCROW_REMINDER_DAY_2=10
ESCROW_REMINDER_DAY_3=13
PLATFORM_FEE_PERCENT=1.0
SELLER_WITHDRAWAL_FEE_PERCENT=1.0
EXTERNAL_TRANSFER_FEE_CAP=30.0
WITHDRAWAL_DELAY_HOURS=24

# Admin
MIN_ADMIN_APPROVALS=2
