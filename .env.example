# Application
APP_NAME=Avok
APP_ENV=production
DEBUG=False
SECRET_KEY=your-secret-key-here-change-in-production
API_V1_PREFIX=/api/v1

# Database
DATABASE_URL=postgresql+asyncpg://avok_user:avok_pass@localhost:5432/avok_db
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=40

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=50

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# JWT
JWT_SECRET_KEY=benjee20avok01la11ha26di99assibi2001
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# AWS S3
AWS_ACCESS_KEY_ID=your-aws-key
AWS_SECRET_ACCESS_KEY=your-aws-secret
AWS_S3_BUCKET=avok-storage
AWS_S3_REGION=us-east-1

# SMS (Africa's Talking)
AFRICASTALKING_USERNAME=sandbox
AFRICASTALKING_API_KEY=your-api-key
AFRICASTALKING_SENDER_ID=AVOK

# Email (SendGrid)
SENDGRID_API_KEY=your-sendgrid-key
SENDGRID_FROM_EMAIL=noreply@avok.com

# Escrow Settings
ESCROW_RELEASE_DAYS=14
ESCROW_REMINDER_DAY_1=7
ESCROW_REMINDER_DAY_2=10
ESCROW_REMINDER_DAY_3=13
PLATFORM_FEE_PERCENT=1.0
SELLER_WITHDRAWAL_FEE_PERCENT=2.0
WITHDRAWAL_DELAY_HOURS=24

# Admin
MIN_ADMIN_APPROVALS=2